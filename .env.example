# App
NEXT_PUBLIC_APP_NAME=PAPS 학생 기록 시스템
# 개발 환경에서는 NEXTAUTH_SECRET이 없으면 로컬 스모크 확인용 fallback secret을 사용합니다.
# 실제 로그인/배포에서는 반드시 명시적으로 설정하세요.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# 둘 중 하나는 반드시 설정해야 교사 로그인이 허용됩니다.
GOOGLE_HOSTED_DOMAIN=school.example.com
TEACHER_EMAIL_ALLOWLIST=teacher@school.example.com

# Google Sheets
GOOGLE_SHEETS_TEMPLATE_ID=your-google-sheets-template-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
